generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
  LAB_TECHNICIAN
  ACCOUNTANT
  PATIENT
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  role            UserRole  @default(PATIENT)
  isActive        Boolean   @default(true)
  isVerified      Boolean   @default(false)
  lastLogin       DateTime?
  refreshToken    String?
  resetToken      String?
  resetTokenExp   DateTime?
  verificationToken String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient            Patient?
  doctor             Doctor?
  staff              Staff?
  notifications      Notification[]
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Patient {
  id              String     @id @default(cuid())
  userId          String     @unique
  registrationNo  String     @unique
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  gender          Gender?
  bloodGroup      BloodGroup?
  phone           String
  alternatePhone  String?
  email           String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  country         String     @default("India")
  occupation      String?
  emergencyContactName String?
  emergencyContactPhone String?
  profileImage    String?
  medicalHistory  Json?
  allergies       String?
  chronicDiseases String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  invoices     Invoice[]
  prescriptions Prescription[]
  labReports   LabReport[]
  medicalRecords MedicalRecord[]
  admissions   Admission[]
  payments     Payment[]

  @@index([registrationNo])
  @@index([phone])
  @@index([firstName, lastName])
}

model Doctor {
  id              String   @id @default(cuid())
  userId          String   @unique
  employeeId      String   @unique
  firstName       String
  lastName        String
  specialization  String
  qualification   String
  experienceYears Int      @default(0)
  licenseNumber   String   @unique
  designation     String
  departmentId    String
  phone           String
  email           String?
  consultationFee Float    @default(0)
  profileImage    String?
  bio             String?
  education       Json?
  experience      Json?
  certifications  Json?
  publications    Json?
  isAvailable     Boolean  @default(true)
  maxPatientsPerDay Int    @default(20)
  averageRating   Float    @default(0)
  totalReviews    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  department        Department         @relation(fields: [departmentId], references: [id])
  appointments      Appointment[]
  prescriptions     Prescription[]
  availability      DoctorAvailability[]
  timeOff           DoctorTimeOff[]
  medicalRecords    MedicalRecord[]
  admissions        Admission[]

  @@index([specialization])
  @@index([departmentId])
  @@index([firstName, lastName])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  image       String?
  color       String?
  isActive    Boolean  @default(true)
  floorNo     String?
  wing        String?
  extensionNo String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors     Doctor[]
  treatments  Treatment[]
  facilities  DepartmentFacility[]
  workingHours DepartmentWorkingHours[]
  appointments Appointment[]
}

model Treatment {
  id           String   @id @default(cuid())
  departmentId String
  name         String
  description  String?
  cost         Float?
  duration     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
}

model DepartmentFacility {
  id           String   @id @default(cuid())
  departmentId String
  name         String
  description  String?
  icon         String?
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
}

model DepartmentWorkingHours {
  id           String    @id @default(cuid())
  departmentId String
  day          DayOfWeek
  openTime     String
  closeTime    String
  isClosed     Boolean   @default(false)
  createdAt    DateTime  @default(now())

  department Department @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, day])
  @@index([departmentId])
}

model DoctorAvailability {
  id        String   @id @default(cuid())
  doctorId  String
  day       DayOfWeek
  startTime String
  endTime   String
  slotDuration Int   @default(30)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, day])
  @@index([doctorId])
}

model DoctorTimeOff {
  id        String   @id @default(cuid())
  doctorId  String
  startDate DateTime
  endDate   DateTime
  reason    String?
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
}

model Appointment {
  id              String            @id @default(cuid())
  appointmentNo   String            @unique
  patientId       String
  doctorId        String
  departmentId    String
  date            DateTime
  startTime       String
  endTime         String
  status          AppointmentStatus @default(SCHEDULED)
  type            String            @default("OPD")
  reason          String?
  symptoms        String?
  notes           String?
  isEmergency     Boolean           @default(false)
  isWalkIn        Boolean           @default(false)
  queueNumber     Int?
  consultationFee Float             @default(0)
  createdBy       String
  cancelledBy     String?
  cancelReason    String?
  rescheduledFrom String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient    Patient   @relation(fields: [patientId], references: [id])
  doctor     Doctor    @relation(fields: [doctorId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  invoice    Invoice?
  medicalRecord MedicalRecord[]

  @@index([patientId])
  @@index([doctorId])
  @@index([date])
  @@index([status])
  @@index([appointmentNo])
}

model MedicalRecord {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  patientId     String
  doctorId      String
  diagnosis     String?
  symptoms      String?
  treatment     String?
  notes         String?
  prescriptions Json?
  labOrders     Json?
  attachments   Json?
  followUpDate  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment  Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient      Patient     @relation(fields: [patientId], references: [id])
  doctor       Doctor      @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
}

model Prescription {
  id          String   @id @default(cuid())
  prescriptionNo String @unique
  patientId   String
  doctorId    String
  diagnosis   String?
  medicines   Json
  labTests    Json?
  notes       String?
  followUpDate DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([prescriptionNo])
}

model Medicine {
  id              String   @id @default(cuid())
  name            String
  genericName     String?
  category        String?
  brand           String?
  manufacturer    String?
  dosageForm      String?
  strength        String?
  unit            String
  pricePerUnit    Float
  stockQuantity   Int      @default(0)
  minStockLevel   Int      @default(10)
  maxStockLevel   Int      @default(100)
  expiryDate      DateTime?
  batchNo         String?
  rackNo          String?
  requiresPrescription Boolean @default(true)
  description     String?
  sideEffects     Json?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseItems    PurchaseOrderItem[]
  salesItems       PharmacySaleItem[]

  @@index([name])
  @@index([category])
  @@index([expiryDate])
}

model PharmacySale {
  id          String        @id @default(cuid())
  invoiceNo   String        @unique
  patientId   String?
  prescriptionId String?
  totalAmount Float
  discount    Float         @default(0)
  tax         Float         @default(0)
  grandTotal  Float
  paymentStatus PaymentStatus @default(PENDING)
  paymentMode String?
  notes       String?
  soldBy      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items   PharmacySaleItem[]
  payment Payment?

  @@index([invoiceNo])
  @@index([createdAt])
}

model PharmacySaleItem {
  id         String   @id @default(cuid())
  saleId     String
  medicineId String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())

  sale     PharmacySale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  medicine Medicine     @relation(fields: [medicineId], references: [id])

  @@index([saleId])
  @@index([medicineId])
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  orderNo         String   @unique
  supplierId      String
  orderDate       DateTime @default(now())
  expectedDate    DateTime?
  status          String   @default("PENDING")
  totalAmount     Float
  notes           String?
  createdBy       String
  approvedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items PurchaseOrderItem[]

  @@index([orderNo])
  @@index([status])
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  purchaseId  String
  medicineId  String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  receivedQty Int      @default(0)
  createdAt   DateTime @default(now())

  purchase PurchaseOrder @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  medicine Medicine      @relation(fields: [medicineId], references: [id])

  @@index([purchaseId])
  @@index([medicineId])
}

model LabTest {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  category       String?
  description    String?
  preparation    String?
  sampleType     String?
  turnaroundTime String?
  cost           Float
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reports LabReport[]

  @@index([category])
}

model LabReport {
  id              String   @id @default(cuid())
  reportNo        String   @unique
  patientId       String
  testId          String
  appointmentId   String?
  doctorId        String?
  prescribedBy    String?
  sampleCollectedAt DateTime?
  sampleType      String?
  resultDate      DateTime?
  results         Json?
  fileUrl         String?
  status          String   @default("PENDING")
  notes           String?
  verifiedBy      String?
  verifiedAt      DateTime?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient  Patient  @relation(fields: [patientId], references: [id])
  test     LabTest   @relation(fields: [testId], references: [id])

  @@index([reportNo])
  @@index([patientId])
  @@index([status])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNo       String        @unique
  patientId       String
  appointmentId   String?       @unique
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  subtotal        Float
  discount        Float         @default(0)
  discountType    String?       @default("PERCENTAGE")
  tax             Float         @default(0)
  total           Float
  paidAmount      Float         @default(0)
  status          InvoiceStatus @default(DRAFT)
  notes           String?
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  patient  Patient   @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  items     InvoiceItem[]
  payment   Payment?

  @@index([invoiceNo])
  @@index([patientId])
  @@index([status])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  totalPrice  Float
  type        String   @default("CONSULTATION")
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id              String        @id @default(cuid())
  paymentNo       String        @unique
  invoiceId       String        @unique
  patientId       String
  pharmacySaleId  String?       @unique
  amount          Float
  paymentMode     String
  transactionId   String?
  status          PaymentStatus @default(PENDING)
  notes           String?
  receivedBy      String
  receivedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  patient       Patient       @relation(fields: [patientId], references: [id])
  pharmacySale  PharmacySale? @relation(fields: [pharmacySaleId], references: [id])

  @@index([paymentNo])
  @@index([invoiceId])
}

model Admission {
  id              String   @id @default(cuid())
  admissionNo     String   @unique
  patientId       String
  doctorId        String
  roomNo          String?
  bedNo           String?
  ward            String?
  admissionDate   DateTime @default(now())
  dischargeDate   DateTime?
  diagnosis       String?
  treatment       String?
  notes           String?
  status          String   @default("ADMITTED")
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  @@index([admissionNo])
  @@index([patientId])
  @@index([status])
}

model Bed {
  id        String  @id @default(cuid())
  bedNo     String
  ward      String
  roomNo    String
  type      String  @default("GENERAL")
  isOccupied Boolean @default(false)
  charge    Float   @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bedNo, ward])
  @@index([ward])
  @@index([isOccupied])
}

model Staff {
  id         String   @id @default(cuid())
  userId     String   @unique
  employeeId String   @unique
  firstName  String
  lastName   String
  department String?
  designation String
  phone      String
  email      String?
  joiningDate DateTime?
  salary     Float?
  shift      String?
  profileImage String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([department])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  category    String?
  tags        Json?
  imageUrl    String?
  author      String
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([isPublished, publishedAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  repliedAt DateTime?
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

model Testimonial {
  id        String   @id @default(cuid())
  patientName String
  content   String
  rating    Int      @default(5)
  imageUrl  String?
  designation String?
  isApproved Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String?
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  group String @default("GENERAL")

  @@index([group])
}
